# Puerto donde corre el servidor Express (npm run dev / npm start).
PORT=3000

# --- Conexión a MySQL (usada en src/config/db.ts) ---

# DB_HOST: dirección del servidor de MySQL.
#   - "localhost" si el MySQL corre en esta misma máquina.
#   - una IP (ej. 192.168.18.219) si el MySQL corre en otra máquina de tu red
#     (por ejemplo tu PC con Windows, si estás desarrollando desde WSL).
DB_HOST=localhost

# DB_USER: nombre de usuario de MySQL con el que se autentica la conexión (ej. root).
# OJO: aquí va un nombre de usuario, NO una IP ni un host.
DB_USER=root

# DB_PASSWORD: contraseña de ese usuario de MySQL.
DB_PASSWORD=

# DB_NAME: nombre de la base de datos creada por database/schema.sql.
DB_NAME=perizone

# --- Autenticación (usada en src/utils/jwt.ts) ---

# JWT_SECRET: clave privada con la que el backend FIRMA y luego VERIFICA los
# tokens de sesión (JWT) que se generan al hacer login. Puede ser cualquier
# texto: no se registra en ningún servicio externo, solo debe mantenerse
# privado (por eso vive en .env, que está en .gitignore y nunca se sube al
# repositorio). Si alguien más conociera este valor, podría fabricar tokens
# válidos y hacerse pasar por cualquier usuario (incluido un administrador).
# Genera uno propio con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# JWT_EXPIRES_IN: tiempo de vida de un token antes de que caduque y el
# usuario tenga que volver a iniciar sesión para obtener uno nuevo.
JWT_EXPIRES_IN=8h
